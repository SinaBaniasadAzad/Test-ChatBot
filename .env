# ---- LLM API ----
# گزینهٔ پیش‌فرض: DeepSeek مستقیم
#DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
#DEEPSEEK_BASE_URL=https://api.deepseek.com
#DEEPSEEK_MODEL=deepseek-chat
#DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ---- گزینهٔ جایگزین: OpenRouter (برای تست اولیه) ----
# کد روی OpenAI SDK سوار است و OpenRouter هم سازگار با OpenAI است؛ پس فقط همین سه
# مقدار را جایگزین کنید (هیچ تغییری در کد لازم نیست). کلید را از openrouter.ai بگیرید.
DEEPSEEK_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324
# نسخهٔ رایگان برای تستِ بی‌هزینه (نرخ محدود): deepseek/deepseek-chat-v3-0324:free

# ---- Behavior ----
# حداکثر تعداد سوال تکمیلی که چت‌بات می‌تواند بپرسد
MAX_QUESTIONS=2
# دمای مدل برای دسته‌بندی (پایین = پایدارتر)
TEMPERATURE=0.0

# ---- Robustness ----
REQUEST_TIMEOUT=60
MAX_RETRIES=3

# ---- Interaction logging (ذخیرهٔ تیکت‌ها، سوال‌های تکمیلی، خروجی مدل) ----
# توجه: لاگ‌ها حاوی دادهٔ پرسنلی (PII) هستند؛ پوشهٔ logs/ در .gitignore است.
INTERACTION_LOG_ENABLED=true
INTERACTION_LOG_PATH=logs/interactions.jsonl

# ---- Ambiguity detection (اختیاری، نردبان تشدید) ----
# اگر روشن باشد، فقط برای موارد لب‌مرزی چند بار نمونه‌گیری می‌کند (self-consistency)
ENABLE_SELF_CONSISTENCY=false
SELF_CONSISTENCY_SAMPLES=3
